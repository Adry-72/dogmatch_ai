# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Required: get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Database (must match backend_node/.env) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dogmatch_db
DB_USER=root
DB_PASSWORD=root

# ── JWT auth (must match JWT_SECRET in backend_node/.env) ──────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable auth (development only)
JWT_SECRET=

# ── CORS (comma-separated list of allowed origins) ─────────────────────────────
# Production example: ALLOWED_ORIGINS=https://dogmatch.it,https://www.dogmatch.it
ALLOWED_ORIGINS=http://localhost:3000

# ── Model settings ─────────────────────────────────────────────────────────────
MODEL=gpt-4o-mini
MAX_TOKENS=1024
MAX_TOOL_ITERATIONS=5
